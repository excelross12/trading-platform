# ── Vercel Postgres ──────────────────────────────────────────
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ── TraderMade API ───────────────────────────────────────────
# Free tier: 1000 req/day — https://tradermade.com
TRADERMADE_API_KEY=

# ── MT5 Socket Proxy ─────────────────────────────────────────
# Local or Oracle VPS running MTsocketAPI EA
MT5_PROXY_HOST=localhost
MT5_PROXY_PORT=77

# ── Alerts ───────────────────────────────────────────────────
# Optional: Slack/Discord webhook for drawdown alerts
ALERT_WEBHOOK_URL=

# ── Cron Security ────────────────────────────────────────────
# Random secret to protect /api/cron/trade from external calls
CRON_SECRET=
